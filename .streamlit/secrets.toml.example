# Streamlit Secrets Configuration
# Copy this file to secrets.toml and fill in your API keys
# DO NOT commit secrets.toml to version control

# FRED API Key (https://fred.stlouisfed.org/docs/api/api_key.html)
[fred]
api_key = "your_real_fred_key_here"

# Twelve Data API Key (https://twelvedata.com/account/api-keys)
[twelve_data]
api_key = "your_real_twelve_data_key_here"

# Supabase Configuration (https://supabase.com/dashboard/project/_/settings/api)
[supabase]
url = "https://your-actual-project-id.supabase.co"
key = "your_actual_supabase_anon_key_here"
